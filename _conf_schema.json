{
  "enabled": {
    "description": "是否开启反机器人检测",
    "type": "bool",
    "default": true
  },
  "negative_keywords": {
    "description": "触发检测的负面关键词列表",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": ["机器人", "bot", "人机", "机机人", "你是机器人", "你是bot"]
  },
  "positive_keywords": {
    "description": "正面评价关键词列表（包含负面关键词但同时包含正面关键词时不触发）",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": ["好", "棒", "赞", "优秀", "聪明", "厉害"]
  },
  "reply_text": {
    "description": "普通触发回复",
    "type": "string",
    "default": "你才是机器人baka！！！😡"
  },
  "at_reply_text": {
    "description": "被@时回复",
    "type": "string",
    "default": "你@我干嘛！有种再说一遍？你才是机器人baka！！！💢"
  },
  "test_reply_text": {
    "description": "测试关键词回复",
    "type": "string",
    "default": "test你妈喵 🤬"
  },
  "add_emoji": {
    "description": "自动加随机表情",
    "type": "bool",
    "default": true
  }
}
